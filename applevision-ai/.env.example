# ==============================================================================
# AppleVision AI – Environment Variables
# ==============================================================================
# Copy this file to .env and update values for your environment.
#
#   cp .env.example .env
# ==============================================================================

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development                # development | production | testing
SECRET_KEY=change-me-in-production   # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL unset to use the default (auto-resolved absolute path).
# SQLite (development):
# DATABASE_URL=sqlite:///instance/applevision_dev.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://applevision:applevision_secret@localhost:5432/applevision_db

# ── ML Model ─────────────────────────────────────────────────────────────────
# Auto-resolved: settings.py picks ONNX > TFLite > Keras based on what exists.
# Uncomment to override (e.g. for local dev with original Keras model):
# MODEL_PATH=../apple-variety-streamlit/model/apple_classifier_final.keras
# LABELS_PATH=../apple-variety-streamlit/labels.json
CONFIDENCE_THRESHOLD=0.75
TOP_K_PREDICTIONS=5

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=200/hour
RATELIMIT_STORAGE_URI=memory://

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Application ───────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
PORT=8000

# ── Docker Compose (PostgreSQL) ──────────────────────────────────────────────
POSTGRES_USER=applevision
POSTGRES_PASSWORD=applevision_secret
POSTGRES_DB=applevision_db
DB_PORT=5432
