# ==============================================================================
# AppleVision AI – Git Ignore
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl

# ── Virtual Environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment Variables ────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Flask / SQLite ───────────────────────────────────────────────────────────
instance/
*.db
*.sqlite3

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── ML Model Files (large – only Keras/H5; TFLite is kept for deployment) ──
*.keras
*.h5
*.pb
saved_model/

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Uploads ──────────────────────────────────────────────────────────────────
uploads/
temp/
